# Copy this file to .env.local and fill in your Azure AD values.
# Obtain these by running:  az login && ./scripts/azure/03_register_ad_apps.sh
# That script also writes .env.local automatically on a fresh run.

AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-gateway-bff-client-id
AZURE_CLIENT_SECRET=your-gateway-bff-client-secret
AZURE_BACKEND_CLIENT_ID=your-backend-api-client-id
